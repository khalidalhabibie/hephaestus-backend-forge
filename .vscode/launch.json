    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to Integrated Browser",
            "request": "attach",
            "type": "editor-browser",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        },
        {
            "type": "java",
            "name": "Day2Application",
            "request": "launch",
            "mainClass": "com.example.day2.Day2Application",
            "projectName": "day2"
        }
    ]
}