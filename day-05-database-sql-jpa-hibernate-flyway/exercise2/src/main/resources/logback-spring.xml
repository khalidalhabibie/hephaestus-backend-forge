<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Structured logging: setiap baris log adalah satu JSON object.
        Mengapa structured logging?
        - Mudah di-query di tools seperti Kibana / Grafana / CloudWatch
        - correlation_id bisa langsung di-filter: {"correlation_id": "REQ-xxx"}
        - Tidak ada ambiguitas parsing format log teks

        MDC (Mapped Diagnostic Context) = "konteks request saat ini"
        RequestIdFilter menyimpan correlation_id ke MDC,
        dan semua log yang terjadi dalam request itu akan otomatis
        menyertakan correlation_id via %X{correlation_id}.
    -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{"timestamp":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","logger":"%logger{36}","correlation_id":"%X{correlation_id:-unknown}","message":"%message"}%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Kurangi noise dari Hibernate SQL di log structured -->
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>

</configuration>