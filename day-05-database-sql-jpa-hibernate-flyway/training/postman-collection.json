    {
      "name": "E2E Full Flow (Runner)",
      "description": "Run top-to-bottom: Create Customer → Loan → Approve → Disburse (auto-schedule) → Get Schedules → Pay → Verify PAID → Search",
      "item": [
        {
          "name": "1 — Create Customer",
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('customerId', pm.response.json().data.id);"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Andi Pratama\",\n  \"nik\": \"3173010101900003\",\n  \"email\": \"andi@mail.com\",\n  \"phone_number\": \"08155512345\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api", "v1", "customers"] } }
        },
        {
          "name": "2 — Create Loan",
          "event": [{ "listen": "test", "script": { "exec": ["pm.collectionVariables.set('loanId', pm.response.json().data.id);"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"customer_id\": \"{{customerId}}\",\n  \"loan_amount\": 12000000,\n  \"tenor_month\": 12,\n  \"purpose\": \"Modal usaha\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/loan-applications", "host": ["{{baseUrl}}"], "path": ["api", "v1", "loan-applications"] } }
        },
        {
          "name": "3 — Approve Loan",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('APPROVED', () => pm.expect(pm.response.json().data.status).to.eql('APPROVED'));"], "type": "text/javascript" } }],
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"status\": \"APPROVED\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/loan-applications/{{loanId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "loan-applications", "{{loanId}}", "status"] } }
        },
        {
          "name": "4 — Disburse Loan (auto-generates 12 schedules)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('DISBURSED', () => pm.expect(pm.response.json().data.status).to.eql('DISBURSED'));"], "type": "text/javascript" } }],
          "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"status\": \"DISBURSED\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/loan-applications/{{loanId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "v1", "loan-applications", "{{loanId}}", "status"] } }
        },
        {
          "name": "5 — Get Schedules (capture scheduleId)",
          "event": [{ "listen": "test", "script": { "exec": ["const data = pm.response.json().data;","pm.test('12 installments', () => pm.expect(data.length).to.eql(12));","if (data.length > 0) {","  pm.collectionVariables.set('scheduleId', data[0].id);","  pm.test('First UNPAID', () => pm.expect(data[0].status).to.eql('UNPAID'));","}"], "type": "text/javascript" } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/loan-applications/{{loanId}}/repayment-schedules", "host": ["{{baseUrl}}"], "path": ["api", "v1", "loan-applications", "{{loanId}}", "repayment-schedules"] } }
        },
        {
          "name": "6 — Make Full Payment (amount = total_amount 1.120.000)",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Payment OK', () => pm.response.to.have.status(200));"], "type": "text/javascript" } }],
          "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"repayment_schedule_id\": \"{{scheduleId}}\",\n  \"payment_reference\": \"PAY-20260621-E2E-001\",\n  \"paid_amount\": 1120000,\n  \"paid_at\": \"2026-06-21T14:00:00+07:00\"\n}" }, "url": { "raw": "{{baseUrl}}/api/v1/payment-transactions", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payment-transactions"] } }
        },
        {
          "name": "7 — Verify Schedule PAID",
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));","pm.test('Schedule is PAID', () => pm.expect(pm.response.json().data.status).to.eql('PAID'));"], "type": "text/javascript" } }],
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/v1/repayment-schedules/{{scheduleId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "repayment-schedules", "{{scheduleId}}"] } }
        },
        {
